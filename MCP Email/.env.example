# Copy this file to ".env" and fill in the real password.
# NEVER commit the real .env file.

# Password for the email account (budi.purwanto@trst.co.id).
# Read at runtime from process.env.EMAIL_PASS — never hardcoded in source.
EMAIL_PASS=your-email-password-here

# Exchange 2007 authenticates against AD via DOMAIN\username, not the SMTP
# address. Override if the domain/sAMAccountName differs.
EMAIL_LOGIN_USER=triasmail\budi.purwanto

# --- Transport (defaults target the stunnel bridge + Exchange 2007) ---------
# IMAP goes through the local stunnel bridge (see stunnel.conf).
IMAP_HOST=127.0.0.1
IMAP_PORT=11993
IMAP_SECURE=false

# SMTP goes directly to the Exchange submission port (465/SMTPS is blocked).
SMTP_HOST=mail.triasmail.co.id
SMTP_PORT=587
SMTP_SECURE=false

# Optional. Not used by the stdio MCP transport; kept for forward-compat.
PORT=3000
